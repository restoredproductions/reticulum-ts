{
  "name": "reticulum-ts",
  "version": "0.1.0",
  "description": "TypeScript port of the Reticulum cryptographic networking stack for React Native/Expo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["reticulum", "mesh-networking", "cryptography", "react-native", "expo"],
  "license": "MIT",
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/ciphers": "^1.2.0",
    "@noble/hashes": "^1.7.0",
    "@msgpack/msgpack": "^3.0.0"
  },
  "peerDependencies": {
    "expo-crypto": ">=12.0.0",
    "expo-file-system": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "expo-crypto": { "optional": true },
    "expo-file-system": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0"
  }
}
